{
  "manifest_version": 3,
  "name": "Germa Search",
  "version": "1.0.0",
  "description": "Advanced search with intelligent Google Dorks - bringing back precise search results",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://openrouter.ai/*"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/48.png",
    "48": "icons/48.png",
    "128": "icons/126.png"
  }
}